# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Database (optional, falls back to SQLite if unset) ---
DATABASE_URL=postgresql://alphaflow:alphaflow@postgres:5432/alphaflow

# --- Redis cache (optional, agent falls back to in-memory if unreachable) ---
REDIS_URL=redis://redis:6379/0

# --- Optional external API keys (system works with free yfinance data if left blank) ---
NEWSAPI_KEY=
FII_DII_API_KEY=
